{
  "description": "SDK entry (createProfile / create_profile) conformance scenarios (wire 0.4). Each scenario drives the SDK entry point as a subprocess. Both reference SDKs assert identical stdout NDJSON event lines and exit codes. Output vocabulary: partial / result / error / permission_request (no session or text events).",
  "scenarios": [
    {
      "name": "async-returns-string",
      "handler": "async_string",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 0, "stdout_lines": ["{\"type\":\"result\",\"text\":\"hello world\"}"] }
    },
    {
      "name": "async-returns-agent-result",
      "handler": "async_result",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 0, "stdout_lines": ["{\"type\":\"result\",\"text\":\"hi there\",\"session_id\":\"sess-abc\"}"] }
    },
    {
      "name": "async-returns-none-after-partial",
      "handler": "async_none_partial",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 0, "stdout_lines": ["{\"type\":\"partial\",\"text\":\"streaming chunk\"}"] }
    },
    {
      "name": "async-raises-protocol-error",
      "handler": "async_protocol_error",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 1, "stdout_lines": ["{\"type\":\"error\",\"message\":\"bad thing\"}"] }
    },
    {
      "name": "async-send-error-then-return",
      "handler": "async_send_error_then_return",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 0, "stdout_lines": ["{\"type\":\"error\",\"message\":\"warn\"}", "{\"type\":\"result\",\"text\":\"after\"}"] },
      "note": "Pins that send_error is non-terminal in both SDKs — the handler may continue and return a body."
    },
    {
      "name": "sync-returns-string",
      "handler": "sync_string",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 0, "stdout_lines": ["{\"type\":\"result\",\"text\":\"hello from sync\"}"] },
      "note": "Pins that a plain (non-async) handler returning a string works on both SDKs."
    },
    {
      "name": "sync-uses-send-partial-bare",
      "handler": "sync_partial_bare",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 0, "stdout_lines": ["{\"type\":\"partial\",\"text\":\"sync chunk\"}", "{\"type\":\"result\",\"text\":\"done\"}"] },
      "note": "Pins that a sync handler can call send_partial / sendPartial without awaiting."
    },
    {
      "name": "async-returns-partial-with-role",
      "handler": "async_partial_with_role",
      "turn": { "message": "hi", "session_id": "", "session_name": "default" },
      "expect": { "exit": 0, "stdout_lines": ["{\"type\":\"partial\",\"text\":\"thinking...\",\"role\":\"thinking\"}", "{\"type\":\"result\",\"text\":\"answer\"}"] },
      "note": "Pins the optional `role` field on partial events across both SDKs."
    },
    {
      "name": "async-permission-roundtrip",
      "handler": "async_permission_roundtrip",
      "turn": { "message": "hi", "session_id": "", "session_name": "default", "permission": true },
      "stdin_after_turn": ["{\"type\":\"permission_response\",\"request_id\":\"r1\",\"behavior\":\"allow\"}"],
      "expect": {
        "exit": 0,
        "stdout_lines": [
          "{\"type\":\"permission_request\",\"request_id\":\"r1\",\"tool_name\":\"Bash\",\"input\":{\"command\":\"echo ok\"},\"description\":\"echo\"}",
          "{\"type\":\"result\",\"text\":\"perm=allow\"}"
        ]
      },
      "note": "Exercises the SDK-side permission channel."
    }
  ]
}
