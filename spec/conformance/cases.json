{
  "_comment": "Conformance cases for stdout NDJSON event classification (wire 0.4). Both classify_line / classifyLine MUST produce the listed object. Legacy session/text types are malformed. Optional session_id on recognised events uses the wire key name.",
  "cases": [
    {"line": "{\"type\":\"session\",\"id\":\"abc-123\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"session\",\"id\":\"abc-123\"}"}},
    {"line": "{\"type\":\"session\",\"id\":\"f47ac10b-58cc-4372\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"session\",\"id\":\"f47ac10b-58cc-4372\"}"}},
    {"line": "{\"type\":\"session\",\"id\":\"\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"session\",\"id\":\"\"}"}},
    {"line": "{\"type\":\"session\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"session\"}"}},
    {"line": "{\"type\":\"session\",\"id\":123}", "expect": {"kind": "malformed", "value": "{\"type\":\"session\",\"id\":123}"}},
    {"line": "{\"type\":\"session\",\"id\":\"multi word id\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"session\",\"id\":\"multi word id\"}"}},
    {"line": "{\"type\":\"session\",\"id\":\"colons:and:slashes-ok\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"session\",\"id\":\"colons:and:slashes-ok\"}"}},

    {"line": "{\"type\":\"partial\",\"text\":\"hello\"}", "expect": {"kind": "partial", "value": "hello"}},
    {"line": "{\"type\":\"partial\",\"text\":\"line1\\nline2\"}", "expect": {"kind": "partial", "value": "line1\nline2"}},
    {"line": "{\"type\":\"partial\",\"text\":\"\"}", "expect": {"kind": "partial", "value": ""}},
    {"line": "{\"type\":\"partial\"}", "expect": {"kind": "partial", "value": ""}},
    {"line": "{\"type\":\"partial\",\"text\":42}", "expect": {"kind": "partial", "value": ""}},
    {"line": "{\"type\":\"partial\",\"text\":\"unicode 你好 🚀\"}", "expect": {"kind": "partial", "value": "unicode 你好 🚀"}},
    {"line": "{\"type\":\"partial\",\"text\":\"x\",\"role\":\"thinking\"}", "expect": {"kind": "partial", "value": "x", "role": "thinking"}},
    {"line": "{\"type\":\"partial\",\"text\":\"y\",\"role\":42}", "expect": {"kind": "partial", "value": "y"}},
    {"line": "{\"type\":\"partial\",\"text\":\"z\",\"session_id\":\"sess-1\"}", "expect": {"kind": "partial", "value": "z", "session_id": "sess-1"}},

    {"line": "{\"type\":\"text\",\"text\":\"hello world\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"text\",\"text\":\"hello world\"}"}},
    {"line": "{\"type\":\"text\",\"text\":\"\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"text\",\"text\":\"\"}"}},
    {"line": "{\"type\":\"text\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"text\"}"}},
    {"line": "{\"type\":\"text\",\"text\":true}", "expect": {"kind": "malformed", "value": "{\"type\":\"text\",\"text\":true}"}},

    {"line": "{\"type\":\"result\",\"text\":\"hello world\"}", "expect": {"kind": "result", "value": "hello world"}},
    {"line": "{\"type\":\"result\",\"text\":\"\"}", "expect": {"kind": "result", "value": ""}},
    {"line": "{\"type\":\"result\"}", "expect": {"kind": "result", "value": ""}},
    {"line": "{\"type\":\"result\",\"text\":true}", "expect": {"kind": "result", "value": ""}},
    {"line": "{\"type\":\"result\",\"text\":\"ok\",\"session_id\":\"s1\"}", "expect": {"kind": "result", "value": "ok", "session_id": "s1"}},

    {"line": "{\"type\":\"error\",\"message\":\"rate limited\"}", "expect": {"kind": "error", "value": "rate limited"}},
    {"line": "{\"type\":\"error\",\"message\":\"\"}", "expect": {"kind": "error", "value": ""}},
    {"line": "{\"type\":\"error\"}", "expect": {"kind": "error", "value": ""}},
    {"line": "{\"type\":\"error\",\"message\":true}", "expect": {"kind": "error", "value": ""}},
    {"line": "{\"type\":\"error\",\"message\":\"boom\",\"session_id\":\"s-err\"}", "expect": {"kind": "error", "value": "boom", "session_id": "s-err"}},

    {"line": "{\"type\":\"permission_request\",\"request_id\":\"1\",\"tool_name\":\"Bash\",\"input\":{}}", "expect": {"kind": "permission_request", "value": {"type": "permission_request", "request_id": "1", "tool_name": "Bash", "input": {}}}},
    {"line": "{\"type\":\"permission_request\",\"request_id\":\"2\",\"tool_name\":\"WebFetch\",\"input\":{\"url\":\"https://x\"}}", "expect": {"kind": "permission_request", "value": {"type": "permission_request", "request_id": "2", "tool_name": "WebFetch", "input": {"url": "https://x"}}}},

    {"line": "hello world", "expect": {"kind": "malformed", "value": "hello world"}},
    {"line": "", "expect": {"kind": "malformed", "value": ""}},
    {"line": "not json", "expect": {"kind": "malformed", "value": "not json"}},
    {"line": "42", "expect": {"kind": "malformed", "value": "42"}},
    {"line": "[1,2,3]", "expect": {"kind": "malformed", "value": "[1,2,3]"}},
    {"line": "{\"foo\":\"bar\"}", "expect": {"kind": "malformed", "value": "{\"foo\":\"bar\"}"}},
    {"line": "{\"type\":\"unknown\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"unknown\"}"}},
    {"line": "{\"type\":\"SESSION\",\"id\":\"x\"}", "expect": {"kind": "malformed", "value": "{\"type\":\"SESSION\",\"id\":\"x\"}"}}
  ]
}
